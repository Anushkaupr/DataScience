  crime_files,
  function(file) {
    read_csv(
      file,
      col_types = cols(.default = col_character()),
      show_col_types = FALSE
    ) %>%
      select(
        Month,
        `LSOA name`,
        `Crime type`
      ) %>%
      mutate(Source_File = file)
  }
) %>%
  mutate(
    Date = ymd(paste0(Month, "-01")),
    
    County = case_when(
      str_detect(
        Source_File,
        regex("norfolk", ignore_case = TRUE)
      ) ~ "NORFOLK",
      
      str_detect(
        Source_File,
        regex("suffolk", ignore_case = TRUE)
      ) ~ "SUFFOLK"
    ),
    
    District = str_remove(
      `LSOA name`,
      "\\s+[0-9]{3}[A-Z]$"
    )
  ) %>%
  filter(
    !is.na(Date),
    !is.na(County),
    !is.na(District),
    District != ""
  )

