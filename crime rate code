# Function for creating the radar chart
create_radar <- function(
    data,
    county_name,
    title_text,
    line_colour,
    fill_colour
) {
  
  county_data <- data %>%
    filter(
      County == county_name
    ) %>%
    arrange(District)
  
  values <- county_data$Rate10k
  names(values) <- county_data$District
  
  if (length(values) < 3) {
    stop(
      paste(
        "Insufficient data for",
        county_name
      )
    )
  }
  
  maximum_value <- max(
    c(values, 1),
    na.rm = TRUE
  )
  
  radar_data <- as.data.frame(
    rbind(
      Maximum = rep(
        maximum_value * 1.1,
        length(values)
      ),
      Minimum = rep(
        0,
        length(values)
      ),
      Rate = values
    )
  )
  
  colnames(radar_data) <- names(values)
  
  radarchart(
    radar_data,
    axistype = 1,
    pcol = line_colour,
    pfcol = adjustcolor(
      fill_colour,
      alpha.f = 0.3
    ),
    plwd = 2,
    vlcex = 0.7,
    title = title_text
  )
}


