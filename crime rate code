# Function for changing a full postcode into a postcode sector
make_sector <- function(x) {
  
  x <- toupper(
    trimws(
      gsub("\\s+", " ", x)
    )
  )
  
  outward <- sub(
    "\\s.*$",
    "",
    x
  )
  
  inward <- sub(
    "^.*\\s",
    "",
    x
  )
  
  paste(
    outward,
    substr(inward, 1, 1)
  )
}


