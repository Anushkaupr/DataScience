# Keep district names in the same format
clean_key <- function(x) {
  x %>%
    as.character() %>%
    str_replace_all("’", "'") %>%
    str_squish() %>%
    str_to_upper() %>%
    str_remove_all("[^A-Z0-9]")
}


# Keep postcodes in the same format
clean_postcode <- function(x) {
  x %>%
    as.character() %>%
    str_to_upper() %>%
    str_remove_all("[^A-Z0-9]")
}


