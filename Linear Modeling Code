# Higher values receive higher scores
higher_is_better <- function(x) {
  
  minimum_value <- min(x, na.rm = TRUE)
  maximum_value <- max(x, na.rm = TRUE)
  
  if (maximum_value == minimum_value) {
    return(rep(100, length(x)))
  }
  
  ((x - minimum_value) /
      (maximum_value - minimum_value)) * 100
}


# Lower values receive higher scores
lower_is_better <- function(x) {
  
  minimum_value <- min(x, na.rm = TRUE)
  maximum_value <- max(x, na.rm = TRUE)
  
  if (maximum_value == minimum_value) {
    return(rep(100, length(x)))
  }
  
  ((maximum_value - x) /
      (maximum_value - minimum_value)) * 100
}


# Create recommendation table
recommendation_table <- model_data %>%
  select(
    District,
    County,
    HousePrice,
    DownloadSpeed,
    DrugRate,
    Attainment8
  ) %>%
  drop_na() %>%
  mutate(
    
    # Higher broadband speed is better
    Broadband_Score = higher_is_better(
      DownloadSpeed
    ),
    
    # Higher Attainment 8 score is better
    School_Score = higher_is_better(
      Attainment8
    ),
    
    # Lower house price is better for affordability
    Affordability_Score = lower_is_better(
      HousePrice
    ),
    
    # Lower drug-offence rate is better
    Safety_Score = lower_is_better(
      DrugRate
    ),
    
    # Equal weighting of 25% for each category
    Overall_Score =
      Broadband_Score * 0.25 +
      School_Score * 0.25 +
      Affordability_Score * 0.25 +
      Safety_Score * 0.25
  ) %>%
  arrange(
    desc(Overall_Score)
  ) %>%
  mutate(
    Rank = row_number(),
    
    Recommendation = case_when(
      Rank == 1 ~ "Best overall",
      Rank <= 3 ~ "Highly recommended",
      Rank <= 6 ~ "Recommended",
      TRUE ~ "Lower overall score"
    )
  ) %>%
  mutate(
    across(
      c(
        Broadband_Score,
        School_Score,
        Affordability_Score,
        Safety_Score,
        Overall_Score
      ),
      ~ round(.x, 2)
    )
  ) %>%
  select(
    Rank,
    District,
    County,
    Broadband_Score,
    School_Score,
    Affordability_Score,
    Safety_Score,
    Overall_Score,
    Recommendation
  )


# Display the final recommendation table
print(
